{
  "name": "cool-ui-monorepo",
  "version": "0.2.0",
  "private": true,
  "description": "Perceptually consistent, platform-native glass UI components.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {"node": ">=22.0.0"},
  "scripts": {
    "build": "pnpm generate && turbo run build",
    "test": "node --test tests/*.test.mjs && turbo run test",
    "test:contracts": "node --test tests/*.test.mjs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build",
    "generate": "pnpm tokens:generate && node scripts/generate-components.mjs && node scripts/generate-sbom.mjs",
    "tokens:generate": "node packages/tokens/scripts/generate.mjs",
    "tokens:check": "node scripts/check-generated.mjs",
    "pack:local": "node scripts/pack-local.mjs",
    "artifacts": "node scripts/build-artifacts.mjs",
    "changeset": "changeset",
    "version-packages": "node scripts/sync-release-version.mjs && pnpm generate",
    "prepublishOnly": "node scripts/guard-public-publish.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "turbo": "^2.5.4",
    "vitepress": "^1.6.3"
  }
}
