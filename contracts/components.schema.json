{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coolui.dev/schemas/components.schema.json",
  "type": "object",
  "required": ["version", "packages", "semanticTypes", "components"],
  "properties": {
    "version": {"const": "0.2.0"},
    "packages": {"type": "object"},
    "semanticTypes": {"type": "object"},
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "category", "platforms", "interactive", "api", "maturity"],
        "properties": {
          "name": {"type": "string"},
          "category": {"type": "string"},
          "platforms": {"const": ["swiftui", "compose", "arkui", "wechat"]},
          "interactive": {"type": "boolean"},
          "states": {"type": "array"},
          "capabilities": {"type": "array"},
          "api": {
            "type": "object",
            "required": ["kind", "valueType", "events", "slots"],
            "properties": {
              "kind": {"enum": ["provider", "container", "action", "textInput", "booleanInput", "choiceInput", "numericInput", "dateInput", "navigation", "content", "status", "presentation"]},
              "valueType": {"enum": ["none", "string", "boolean", "number", "date"]},
              "events": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
              "slots": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
              "models": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
            },
            "additionalProperties": false
          },
          "maturity": {
            "type": "object",
            "required": ["swiftui", "compose", "arkui", "wechat"],
            "properties": {
              "swiftui": {"enum": ["stable", "beta", "planned"]},
              "compose": {"enum": ["stable", "beta", "planned"]},
              "arkui": {"enum": ["stable", "beta", "planned"]},
              "wechat": {"enum": ["stable", "beta", "planned"]}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  }
}
