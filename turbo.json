{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {"dependsOn": ["^build"], "outputs": ["dist/**", "build/**", ".vitepress/dist/**"]},
    "test": {"dependsOn": ["build"], "outputs": ["coverage/**", "test-results/**"]},
    "lint": {"dependsOn": ["^lint"]},
    "typecheck": {"dependsOn": ["^typecheck"]},
    "docs:build": {"dependsOn": ["^build"], "outputs": ["docs/.vitepress/dist/**"]},
    "dev": {"cache": false, "persistent": true}
  }
}
