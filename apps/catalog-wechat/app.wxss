@import "../../packages/wechat/dist/styles/tokens.wxss";

page { min-height: 100%; background: var(--cool-color-dark-background); color: var(--cool-color-dark-text); }
.catalog-shell { position: relative; min-height: 100vh; padding: 96rpx 32rpx 64rpx; overflow: hidden; }
.catalog-orb { position: fixed; width: 520rpx; height: 520rpx; border-radius: 999rpx; filter: blur(64rpx); opacity: var(--cool-lighting-backdropGlowOpacity); pointer-events: none; }
.catalog-orb-cyan { top: -180rpx; right: -160rpx; background: var(--cool-color-dark-accent); }
.catalog-orb-amber { bottom: -220rpx; left: -180rpx; background: var(--cool-color-dark-warning); }
.catalog-header, .catalog-section { position: relative; z-index: 1; }
.catalog-header { margin-bottom: 64rpx; }
.catalog-eyebrow { display: block; color: var(--cool-color-dark-accent); font-size: 22rpx; letter-spacing: 4rpx; }
.catalog-title { display: block; margin-top: 16rpx; font-size: 64rpx; font-weight: 650; line-height: 1.05; }
.catalog-copy { display: block; margin-top: 24rpx; color: var(--cool-color-dark-textSecondary); font-size: 28rpx; }
.catalog-section { margin-top: 48rpx; }
.catalog-section-title { display: block; margin-bottom: 20rpx; color: var(--cool-color-dark-textSecondary); font-size: 24rpx; text-transform: uppercase; letter-spacing: 2rpx; }
.catalog-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20rpx; }
